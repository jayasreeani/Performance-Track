// Database class definition
class Database {
    constructor() {
        this.init();
    }

    // Calculate dynamic experience in years & months
    calculateExperience(joiningDateStr) {
        if (!joiningDateStr) return '0 mos';
        const joinDate = new Date(joiningDateStr);
        const now = new Date();
        
        let months = (now.getFullYear() - joinDate.getFullYear()) * 12;
        months -= joinDate.getMonth();
        months += now.getMonth();
        
        if (now.getDate() < joinDate.getDate()) {
            months--; 
        }
        
        if (months < 0) return '0 mos';
        
        const yrs = Math.floor(months / 12);
        const mos = months % 12;
        
        if (yrs === 0) {
            return `${mos} mo${mos !== 1 ? 's' : ''}`;
        } else {
            return `${yrs} yr${yrs !== 1 ? 's' : ''} ${mos} mo${mos !== 1 ? 's' : ''}`;
        }
    }

    init() {
        if (!localStorage.getItem(STORAGE_KEYS.PROJECTS)) {
            localStorage.setItem(STORAGE_KEYS.PROJECTS, JSON.stringify(DEFAULT_PROJECTS));
        }
        
        // Migration check: Reset employees if they use old schema without designation or joiningDate
        let resetEmployees = false;
        try {
            const currentEmps = JSON.parse(localStorage.getItem(STORAGE_KEYS.EMPLOYEES));
            if (currentEmps && currentEmps.length > 0 && !currentEmps[0].joiningDate) {
                resetEmployees = true;
            }
        } catch(e) {
            resetEmployees = true;
        }

        if (!localStorage.getItem(STORAGE_KEYS.EMPLOYEES) || resetEmployees) {
            localStorage.setItem(STORAGE_KEYS.EMPLOYEES, JSON.stringify(DEFAULT_EMPLOYEES));
        }

        // Migration check for multiple projects: add projectIds array if missing
        try {
            const currentEmps = JSON.parse(localStorage.getItem(STORAGE_KEYS.EMPLOYEES));
            if (currentEmps && currentEmps.length > 0) {
                let migrated = false;
                const updatedEmps = currentEmps.map(emp => {
                    if (!emp.projectIds) {
                        emp.projectIds = emp.projectId ? [emp.projectId] : [];
                        migrated = true;
                    }
                    return emp;
                });
                if (migrated) {
                    localStorage.setItem(STORAGE_KEYS.EMPLOYEES, JSON.stringify(updatedEmps));
                }
            }
        } catch (e) {
            console.error("Failed to migrate employees project structure", e);
        }

        // Migration check: Reset KPIs and Evaluations if they use old schema (missing common property)
        let resetKpis = false;
        try {
            const currentKpis = JSON.parse(localStorage.getItem(STORAGE_KEYS.KPIS));
            if (currentKpis && !currentKpis.common) {
                resetKpis = true;
            }
        } catch(e) {
            resetKpis = true;
        }

        if (!localStorage.getItem(STORAGE_KEYS.KPIS) || resetKpis) {
            localStorage.setItem(STORAGE_KEYS.KPIS, JSON.stringify(DEFAULT_KPIS));
            localStorage.setItem(STORAGE_KEYS.EVALUATIONS, JSON.stringify(DEFAULT_EVALUATIONS));
        } else {
            // Migration check for Business Analyst: seed targets if missing
            try {
                const currentKpis = JSON.parse(localStorage.getItem(STORAGE_KEYS.KPIS));
                if (currentKpis && currentKpis.targets && !currentKpis.targets['Business Analyst']) {
                    currentKpis.targets['Business Analyst'] = DEFAULT_KPIS.targets['Business Analyst'];
                    localStorage.setItem(STORAGE_KEYS.KPIS, JSON.stringify(currentKpis));
                }
            } catch (e) {
                console.error("Failed to migrate KPIs structure for Business Analyst", e);
            }
            if (!localStorage.getItem(STORAGE_KEYS.EVALUATIONS)) {
                localStorage.setItem(STORAGE_KEYS.EVALUATIONS, JSON.stringify(DEFAULT_EVALUATIONS));
            }
        }

        if (!localStorage.getItem(STORAGE_KEYS.SETTINGS)) {
            localStorage.setItem(STORAGE_KEYS.SETTINGS, JSON.stringify(DEFAULT_SETTINGS));
        }
    }

    // Reset database to default seed data
    resetToDefaults() {
        localStorage.setItem(STORAGE_KEYS.PROJECTS, JSON.stringify(DEFAULT_PROJECTS));
        localStorage.setItem(STORAGE_KEYS.EMPLOYEES, JSON.stringify(DEFAULT_EMPLOYEES));
        localStorage.setItem(STORAGE_KEYS.KPIS, JSON.stringify(DEFAULT_KPIS));
        localStorage.setItem(STORAGE_KEYS.EVALUATIONS, JSON.stringify(DEFAULT_EVALUATIONS));
        localStorage.setItem(STORAGE_KEYS.SETTINGS, JSON.stringify(DEFAULT_SETTINGS));
    }

    // Projects CRUD
    getProjects() {
        return JSON.parse(localStorage.getItem(STORAGE_KEYS.PROJECTS)) || [];
    }

    saveProjects(projects) {
        localStorage.setItem(STORAGE_KEYS.PROJECTS, JSON.stringify(projects));
    }

    addProject(project) {
        const projects = this.getProjects();
        project.id = 'p_' + Date.now();
        projects.push(project);
        this.saveProjects(projects);
        return project;
    }

    updateProject(updatedProject) {
        let projects = this.getProjects();
        projects = projects.map(p => p.id === updatedProject.id ? updatedProject : p);
        this.saveProjects(projects);
    }

    deleteProject(id) {
        let projects = this.getProjects();
        projects = projects.filter(p => p.id !== id);
        this.saveProjects(projects);
        
        // Unassign employees from this project
        let employees = this.getEmployees();
        employees = employees.map(emp => {
            if (emp.projectId === id) {
                emp.projectId = ''; // Unassigned
            }
            if (emp.projectIds) {
                emp.projectIds = emp.projectIds.filter(pid => pid !== id);
            }
            return emp;
        });
        this.saveEmployees(employees);
    }

    // Employees CRUD
    getEmployees() {
        return JSON.parse(localStorage.getItem(STORAGE_KEYS.EMPLOYEES)) || [];
    }

    saveEmployees(employees) {
        localStorage.setItem(STORAGE_KEYS.EMPLOYEES, JSON.stringify(employees));
    }

    addEmployee(employee) {
        const employees = this.getEmployees();
        employee.id = 'e_' + Date.now();
        employees.push(employee);
        this.saveEmployees(employees);
        return employee;
    }

    updateEmployee(updatedEmployee) {
        let employees = this.getEmployees();
        employees = employees.map(e => e.id === updatedEmployee.id ? updatedEmployee : e);
        this.saveEmployees(employees);
    }

    deleteEmployee(id) {
        let employees = this.getEmployees();
        employees = employees.filter(e => e.id !== id);
        this.saveEmployees(employees);

        // Delete evaluations associated with this employee
        let evals = this.getEvaluations();
        evals = evals.filter(ev => ev.employeeId !== id);
        this.saveEvaluations(evals);
    }

    // KPI Configurations CRUD
    getKPIs() {
        return JSON.parse(localStorage.getItem(STORAGE_KEYS.KPIS)) || {};
    }

    saveKPIs(kpis) {
        localStorage.setItem(STORAGE_KEYS.KPIS, JSON.stringify(kpis));
    }

    getKPIsByRole(role) {
        const allKPIs = this.getKPIs();
        const common = allKPIs.common || [];
        const roleTargets = (allKPIs.targets && allKPIs.targets[role]) || {};
        
        return common.map(kpi => {
            const config = roleTargets[kpi.id];
            
            // Allow override of weight or target if stored in DB
            let weight = kpi.weight;
            let target = kpi.kpi; // Fallback to common KPI detail text
            
            if (config) {
                if (typeof config.weight !== 'undefined') weight = config.weight;
                if (typeof config.target !== 'undefined') target = config.target;
            }
            
            return {
                id: kpi.id,
                category: kpi.category,
                kra: kpi.kra,
                name: kpi.kra, // Use KRA Name for display name
                desc: kpi.desc,
                kpi: kpi.kpi,
                weight: weight,
                target: target
            };
        });
    }

    updateKPIsForRole(role, kpiArray) {
        const allKPIs = this.getKPIs();
        if (!allKPIs.targets) allKPIs.targets = {};
        if (!allKPIs.targets[role]) allKPIs.targets[role] = {};
        
        kpiArray.forEach(kpi => {
            allKPIs.targets[role][kpi.id] = {
                target: kpi.target,
                weight: kpi.weight
            };
        });
        
        this.saveKPIs(allKPIs);
    }

    // Evaluations CRUD
    getEvaluations() {
        return JSON.parse(localStorage.getItem(STORAGE_KEYS.EVALUATIONS)) || [];
    }

    saveEvaluations(evals) {
        localStorage.setItem(STORAGE_KEYS.EVALUATIONS, JSON.stringify(evals));
    }

    addEvaluation(evaluation) {
        const evals = this.getEvaluations();
        
        // Check if evaluation already exists for this employee and period
        const existingIndex = evals.findIndex(ev => ev.employeeId === evaluation.employeeId && ev.period === evaluation.period);
        
        evaluation.updatedAt = new Date().toISOString();
        
        if (existingIndex > -1) {
            evaluation.id = evals[existingIndex].id;
            evals[existingIndex] = evaluation;
        } else {
            evaluation.id = 'ev_' + Date.now();
            evals.push(evaluation);
        }
        
        this.saveEvaluations(evals);
        return evaluation;
    }

    deleteEvaluation(id) {
        let evals = this.getEvaluations();
        evals = evals.filter(ev => ev.id !== id);
        this.saveEvaluations(evals);
    }

    // Settings
    getSettings() {
        return JSON.parse(localStorage.getItem(STORAGE_KEYS.SETTINGS)) || DEFAULT_SETTINGS;
    }

    saveSettings(settings) {
        localStorage.setItem(STORAGE_KEYS.SETTINGS, JSON.stringify(settings));
    }
}

// Attach Database to window object
window.DB = new Database();
